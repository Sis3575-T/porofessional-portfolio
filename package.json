{
  "name": "portfolio-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:all": "concurrently -n api,web,admin -c cyan,green,magenta \"node --watch services/backend/src/server.js\" \"cd apps/web && npm run dev\" \"cd apps/admin && npm run dev\"",
    "dev:backend": "node --watch services/backend/src/server.js",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "start": "node services/backend/src/server.js"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
